{
  "name": "siabanni-transcribe",
  "version": "1.0.0",
  "description": "Siabanni Transcribe — Application de transcription automatique de reunions et entretiens (FR/EN) avec resume IA et export Word/PDF/TXT. Developpee par le Consortium SFR.",
  "main": "src/main/main.js",
  "author": {
    "name": "Consortium SFR",
    "email": "contact@consortium-sfr.local"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "docx": "^8.5.0",
    "electron-store": "^8.2.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "nodejs-whisper": "^0.1.18",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.consortiumsfr.siabanni",
    "productName": "Siabanni Transcribe",
    "copyright": "Copyright (c) 2026 Consortium SFR",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "models",
        "to": "models",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}